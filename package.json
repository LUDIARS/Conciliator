{
  "name": "conciliator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "git が苦手なバイナリ/非マージファイルの作業衝突を検知・予防・マージ支援するローカル常駐サービス",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:web": "cd web && npm run dev",
    "build": "tsc && cd web && npm run build",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^3.6.0",
    "fast-xml-parser": "^5.9.3",
    "fflate": "^0.8.2",
    "hono": "^4.6.14",
    "node-notifier": "^10.0.1",
    "picomatch": "^4.0.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-notifier": "^8.0.5",
    "@types/picomatch": "^3.0.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
